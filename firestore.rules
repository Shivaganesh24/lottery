rules_version = '2';

/**
 * FIRESTORE SECURITY RULES
 * 
 * CORE PHILOSOPHY:
 * This ruleset enforces a strict user-ownership model combined with Database-Based Access Control (DBAC) 
 * for administrative privileges. It prioritizes "Authorization Independence" by ensuring that 
 * authorization decisions can be made using only the information present in the request path 
 * or the document itself, avoiding expensive cross-document lookups (get() calls) whenever possible.
 * 
 * DATA STRUCTURE:
 * - /users/{userId}: Private user profile information.
 * - /users/{userId}/subscriptions: User-specific subscription history.
 * - /users/{userId}/winnings: User-specific prize draw results and claims.
 * - /subscriptionPlans, /charities, /draws, /prizes: Publicly readable global configuration and event data.
 * - /admin_users: A restricted collection where the existence of a document grants administrative rights.
 */

service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    /** @description Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the user is an administrator by verifying the existence of their UID in the admin collection. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admin_users/$(request.auth.uid));
    }

    /** @description Combines ownership check with a check for document existence for updates and deletes. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for user profile documents.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if (isExistingOwner(userId) || isAdmin()) && request.resource.data.id == resource.data.id;
      allow delete: if isAdmin();
    }

    /**
     * @description Rules for the admin registry.
     */
    match /admin_users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isOwner(userId); 
      allow update, delete: if isAdmin();
    }

    /**
     * @description Rules for global public collections.
     */
    match /subscriptionPlans/{id} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /charities/{id} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /prizes/{id} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /draws/{id} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Rules for user-specific subscriptions.
     */
    match /users/{userId}/subscriptions/{subscriptionId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if (isExistingOwner(userId) || isAdmin()) && request.resource.data.userId == resource.data.userId;
      allow delete: if isAdmin();
    }

    /**
     * @description Rules for winning records. 
     * Includes collectionGroup support to allow admins to fetch all winnings across all users.
     */
    match /users/{userId}/winnings/{winningId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isAdmin();
      allow update: if (isExistingOwner(userId) || isAdmin()) && request.resource.data.userId == resource.data.userId;
      allow delete: if isAdmin();
    }

    // COLLECTION GROUP: Allow admins to list and get winnings from any path
    match /{path=**}/winnings/{winningId} {
      allow list, get: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

  }
}