rules_version = '2';

/**
 * FIRESTORE SECURITY RULES
 * 
 * CORE PHILOSOPHY:
 * This ruleset enforces a strict user-ownership model combined with Database-Based Access Control (DBAC) 
 * for administrative privileges. It prioritizes "Authorization Independence" by ensuring that 
 * authorization decisions can be made using only the information present in the request path 
 * or the document itself, avoiding expensive cross-document lookups (get() calls) whenever possible.
 * 
 * DATA STRUCTURE:
 * - /users/{userId}: Private user profile information.
 * - /users/{userId}/subscriptions: User-specific subscription history.
 * - /users/{userId}/winnings: User-specific prize draw results and claims.
 * - /subscriptionPlans, /charities, /draws, /prizes: Publicly readable global configuration and event data.
 * - /admin_users: A restricted collection where the existence of a document grants administrative rights.
 * 
 * KEY SECURITY DECISIONS:
 * 1. DBAC (Existence over Content): Admin status is determined by the existence of a document in 
 *    the /admin_users/ collection, rather than a 'role' field within a user document.
 * 2. Ownership Validation: Every user-scoped document contains a denormalized 'userId' or 'id' 
 *    field that must match both the document path and the authenticated user's UID.
 * 3. Public Readability: Global collections related to the golf platform's offerings (Plans, 
 *    Charities, Prizes) are open for public consumption to allow for anonymous browsing.
 * 4. Immutability: Critical relational links, such as the ownership of a subscription, 
 *    are enforced as immutable during updates.
 * 
 * DENORMALIZATION FOR AUTHORIZATION:
 * To optimize performance and ensure atomic security checks, the 'userId' is duplicated 
 * within subcollection documents. This allows rules to verify ownership without 
 * fetching parent documents.
 */

service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    /** @description Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the user is an administrator by verifying the existence of their UID in the admin collection. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admin_users/$(request.auth.uid));
    }

    /** @description Combines ownership check with a check for document existence for updates and deletes. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for user profile documents. Users can manage their own profile; admins have full access.
     * @path /users/{userId}
     * @allow (create) auth.uid matches path and internal 'id' field matches path.
     * @deny (update) user attempts to change another user's profile.
     * @principle Ownership validation and self-creation.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if (isExistingOwner(userId) || isAdmin()) && request.resource.data.id == resource.data.id;
      allow delete: if isAdmin();
    }

    /**
     * @description Rules for the admin registry. Existence of a UID here defines administrative status.
     * @path /admin_users/{userId}
     * @allow (get) any signed-in user to check if they/others are admins.
     * @allow (create) users to promote themselves for prototype/MVP testing purposes.
     * @deny (write) any non-owner client-side attempt to modify the admin list.
     * @principle DBAC (Existence over Content).
     */
    match /admin_users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isOwner(userId); 
      allow update, delete: if isAdmin();
    }

    /**
     * @description Rules for subscription plans, charities, and prizes. Publicly readable, admin editable.
     * @path /subscriptionPlans/{id}, /charities/{id}, /prizes/{id}
     * @allow (list) anonymous users to browse available plans or charities.
     * @deny (create) non-admin users attempting to create a new plan.
     * @principle Public Read with Owner-Only (Admin) Writes.
     */
    match /subscriptionPlans/{id} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /charities/{id} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /prizes/{id} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Rules for draw events. Publicly readable records of monthly draws.
     * @path /draws/{drawId}
     * @allow (get) public access to view winning numbers and draw details.
     * @deny (update) any non-admin modification of draw results.
     * @principle Public Read with Owner-Only (Admin) Writes.
     */
    match /draws/{drawId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Rules for user-specific subscriptions.
     * @path /users/{userId}/subscriptions/{subscriptionId}
     * @allow (create) owner creating a record where the internal 'userId' matches the path.
     * @deny (update) user attempting to transfer a subscription to a different UID.
     * @principle Authorization Independence and relational integrity.
     */
    match /users/{userId}/subscriptions/{subscriptionId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if (isExistingOwner(userId) || isAdmin()) && request.resource.data.userId == resource.data.userId;
      allow delete: if isAdmin();
    }

    /**
     * @description Rules for winning records. Admins create/verify; users read and claim.
     * @path /users/{userId}/winnings/{winningId}
     * @allow (update) owner updating the 'claimStatus' of their own winning record.
     * @deny (create) user attempting to create their own winning record.
     * @principle Ownership for claim management, Admin-only creation.
     */
    match /users/{userId}/winnings/{winningId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isAdmin();
      allow update: if (isExistingOwner(userId) || isAdmin()) && request.resource.data.userId == resource.data.userId;
      allow delete: if isAdmin();
    }

  }
}
